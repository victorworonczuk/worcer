# Copiar como .env.local para desarrollo local.
# En producción, cargar estas mismas variables en Vercel: Project Settings → Environment Variables.

# Valor aleatorio (ej: openssl rand -hex 24). Firma la cookie de sesión del login (HMAC).
SESSION_SECRET=
RESEND_API_KEY=
# Connection string de Postgres (Supabase → Settings → Database).
# La necesitan los scripts de import-*.cjs Y la ruta /api/login (valida contra la tabla usuarios).
DATABASE_URL=
