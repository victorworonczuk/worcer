# Copiar como .env.local para desarrollo local.
# En producción, cargar estas mismas variables en Vercel: Project Settings → Environment Variables.

BASIC_AUTH_USER=
BASIC_AUTH_PASS=
# Valor aleatorio (ej: openssl rand -hex 24). Es el token de la cookie de sesión del login.
SESSION_SECRET=
RESEND_API_KEY=
# Connection string de Postgres (Supabase → Settings → Database), solo para los scripts de import-*.cjs.
DATABASE_URL=
